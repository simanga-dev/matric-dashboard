# ── Database ──────────────────────────────────────────
POSTGRES_DB=matric_dashboard
POSTGRES_USER=matric
POSTGRES_PASSWORD=

# ── MinIO (S3-compatible file storage) ───────────────
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=
FILE_STORAGE_BUCKET=matric-dasbhoard-files

# ── JWT / Auth ───────────────────────────────────────
# Generate a secure key: openssl rand -base64 64
JWT_SECRET=
# 32+ chars: openssl rand -base64 32
EXT_AUTH_ENCRYPTION_KEY=

# ── Email (SMTP) ─────────────────────────────────────
EMAIL_ENABLED=false
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_FROM_NAME=MatricDasbhoard
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_SSL=false

# ── Captcha (Cloudflare Turnstile) ───────────────────
TURNSTILE_SECRET_KEY=

# ── Frontend ─────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
TURNSTILE_SITE_KEY=1x00000000000000000000AA

# ── CORS ─────────────────────────────────────────────
CORS_ALLOW_ALL=false
