{
	"Serilog": {
		"MinimumLevel": {
			"Default": "Information",
			"Override": {
				"Microsoft": "Information",
				"Microsoft.AspNetCore": "Error",
				"Microsoft.EntityFrameworkCore": "Warning"
			}
		},
		"Enrich": ["FromLogContext"]
	},
	"ConnectionStrings": {
		"Database": "<DB_CONNECTION_STRING>"
	},
	"Caching": {
		"Enabled": true,
		"DefaultExpiration": "00:10:00"
	},
	"RateLimiting": {
		"Global": {
			"PermitLimit": 120,
			"Window": "00:01:00",
			"QueueLimit": 0,
			"QueueProcessingOrder": "OldestFirst"
		},
		"Registration": {
			"PermitLimit": 10,
			"Window": "00:01:00",
			"QueueLimit": 0,
			"QueueProcessingOrder": "OldestFirst"
		},
		"Auth": {
			"PermitLimit": 10,
			"Window": "00:01:00",
			"QueueLimit": 0,
			"QueueProcessingOrder": "OldestFirst"
		},
		"Sensitive": {
			"PermitLimit": 5,
			"Window": "00:05:00",
			"QueueLimit": 0,
			"QueueProcessingOrder": "OldestFirst"
		},
		"AdminMutations": {
			"PermitLimit": 30,
			"Window": "00:01:00",
			"QueueLimit": 0,
			"QueueProcessingOrder": "OldestFirst"
		}
	},
	"Authentication": {
		"Jwt": {
			"Key": "4i4zADPWp1zFrQPr+TeHfY9rHeEUJqr4s4Fsjw+NHVRTawfRmYi+cPMsntu+PYlEcN6TgovWiFUJ3ZHb61tniA==",
			"Issuer": "MatricDasbhoardIssuer",
			"Audience": "MatricDasbhoardAudience",
			"AccessTokenLifetime": "00:10:00",
			"SecurityStampClaimType": "security_stamp",
			"RefreshToken": {
				"PersistentLifetime": "7.00:00:00",
				"SessionLifetime": "1.00:00:00"
			}
		},
		"EmailToken": {
			"TokenLengthInBytes": 32,
			"Lifetime": "1.00:00:00"
		},
		"TwoFactor": {
			"ChallengeLifetime": "00:05:00",
			"Issuer": "MatricDasbhoard",
			"MaxChallengeAttempts": 5
		},
		"ExternalProviders": {
			"AllowedRedirectUris": ["https://your-production-domain.com/oauth/callback"],
			"StateLifetime": "00:10:00",
			"EncryptionKey": "4unz///uK7fWkx1VBQ1BTOU8+ZBpVvEPIjAsw7kBz/k="
		}
	},
	"Email": {
		"Enabled": false,
		"FromAddress": "noreply@example.com",
		"FromName": "MatricDasbhoard",
		"FrontendBaseUrl": "https://your-production-domain.com",
		"Smtp": {
			"Host": "",
			"Port": 587,
			"Username": "",
			"Password": "",
			"UseSsl": true
		}
	},
	"JobScheduling": {
		"Enabled": true,
		"WorkerCount": 4
	},
	"FileStorage": {
		"Endpoint": "<FILE_STORAGE_ENDPOINT>",
		"AccessKey": "<FILE_STORAGE_ACCESS_KEY>",
		"SecretKey": "<FILE_STORAGE_SECRET_KEY>",
		"BucketName": "matric-dasbhoard-files",
		"UseSSL": true
	},
	"Captcha": {
		"SecretKey": "<TURNSTILE_SECRET_KEY>"
	},
	"Cors": {
		"AllowAllOrigins": false,
		"AllowedOrigins": ["https://your-production-domain.com"],
		"PolicyName": "DefaultCorsPolicy"
	},
	"Hosting": {
		"ForceHttps": true,
		"ReverseProxy": {
			"TrustedNetworks": [],
			"TrustedProxies": []
		}
	},
	"AllowedHosts": "*"
}
