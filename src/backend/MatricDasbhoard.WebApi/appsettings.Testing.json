{
	"Serilog": {
		"MinimumLevel": {
			"Default": "Warning"
		}
	},
	"ConnectionStrings": {
		"Database": "Host=localhost;Database=test_db;Username=test;Password=test"
	},
	"Authentication": {
		"Jwt": {
			"Key": "ThisIsATestOnlyJwtSigningKeyThatIsAtLeast64CharactersLongForTests!",
			"Issuer": "test-issuer",
			"Audience": "test-audience"
		},
		"ExternalProviders": {
			"AllowedRedirectUris": ["https://test.example.com/oauth/callback"],
			"EncryptionKey": "ThisIsATestOnlyEncryptionKeyThatMustBeAtLeast32CharactersLong!!"
		}
	},
	"Caching": {
		"Enabled": false
	},
	"JobScheduling": {
		"Enabled": false
	},
	"Email": {
		"Enabled": false,
		"FrontendBaseUrl": "https://test.example.com"
	},
	"Captcha": {
		"SecretKey": "1x0000000000000000000000000000000AA"
	},
	"FileStorage": {
		"Endpoint": "http://localhost:9000",
		"AccessKey": "testaccess",
		"SecretKey": "testsecret",
		"BucketName": "test-files",
		"UseSSL": false
	},
	"RateLimiting": {
		"Global": {
			"PermitLimit": 10000,
			"Window": "00:00:10"
		},
		"Registration": {
			"PermitLimit": 10000,
			"Window": "00:00:10"
		},
		"Auth": {
			"PermitLimit": 10000,
			"Window": "00:00:10"
		},
		"Sensitive": {
			"PermitLimit": 10000,
			"Window": "00:00:10"
		},
		"AdminMutations": {
			"PermitLimit": 10000,
			"Window": "00:00:10"
		}
	},
	"Hosting": {
		"ForceHttps": false
	},
	"Cors": {
		"AllowAllOrigins": false,
		"AllowedOrigins": ["https://test.example.com"],
		"PolicyName": "DefaultCorsPolicy"
	}
}
